# ==========================
# Oracle Configuration
# ==========================

ORACLE_USER=sys
ORACLE_PASSWORD=oracle_password
ORACLE_DSN=localhost:1521/ord
ORACLE_SYSDBA=true

# ==========================
# Groq Configuration
# ==========================

GROQ_API_KEY=your_groq_api_key

DEFAULT_MODEL=qwen/qwen3-32b
FALLBACK_MODEL_1=qwen/qwen3-14b
FALLBACK_MODEL_2=qwen/qwen3-8b

# ==========================
# Application
# ==========================

LOG_LEVEL=INFO
TOP_K_SCHEMA=5
VECTOR_STORE_PATH=vector_store
LOG_DIR=logs